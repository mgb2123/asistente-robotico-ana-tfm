# Secretos del robot Ana. Copia este fichero y rellena los valores reales:
#   cp secrets.env.example secrets.env  &&  nano secrets.env
# secrets.env está en .gitignore (*.env): nunca se sube al repo.
# Se carga solo con ./lanzar.sh, o a mano con:  source secrets.env

# --- LLM (OpenRouter) --- OBLIGATORIO
export OPENROUTER_API_KEY=""   # sk-or-...  -> https://openrouter.ai/keys

# --- Emergencias (Twilio) --- OPCIONAL (sin esto no llama; el resto funciona igual)
export TWILIO_SID=""           # ACxxxx...  -> console.twilio.com
export TWILIO_TOKEN=""         # auth token de la misma consola
export TWILIO_FROM=""          # +34...  número Twilio emisor
export TWILIO_TO=""            # +34...  número destino (familiar / cuidador)

# URL WebSocket del bridge de audio bidireccional (bridge_twilio_emergencia.py).
# El bridge corre en la RPi y se expone con ngrok:
#   python3 bridge_twilio_emergencia.py --port 8080 &
#   ngrok http 8080
# Luego copia aquí la URL wss:// que ngrok muestra.
# Si se deja vacío: la llamada usa <Say> + <Hangup/> (solo mensaje de voz).
export TWILIO_BRIDGE_URL=""    # p.ej. wss://xxxx.ngrok.io/twilio/bridge
